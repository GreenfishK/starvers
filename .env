#############################################################
# starvers.eval.compose.yml
#############################################################
base_host_dir=/mnt/data/starvers_eval/latest

# datasets: bearb_day bearb_hour bearc orkg
datasets=bearb_day bearb_hour bearc orkg

# policies: ic_sr_ng tb_sr_ng tb_sr_rs ostrich
policies=ic_sr_ng tb_sr_ng tb_sr_rs ostrich

# triple_stores: graphdb jenatdb2 ostrich
triple_stores=graphdb jenatdb2 ostrich

# construct_datasets configs: whether or not to skip the construction of any of the datasets
skip_change_sets=True
skip_tb_star_ds=True
skip_icng_ds=True
skip_tb_ds=False

#############################################################
# starversserver.eval.compose.yml, starversserver.prod.compose.yml
#############################################################
data_storage=/mnt/data/starversserver

#############################################################
# starversserver.dev.compose.yml
#############################################################
data_storage_dev=/mnt/data/starversserver_dev